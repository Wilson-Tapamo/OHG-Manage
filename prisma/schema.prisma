generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DIRECTOR
  CONSULTANT
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectType {
  JURIDIQUE
  FINANCIER
  FISCAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ConsultantLevel {
  JUNIOR
  INTERMEDIATE
  SENIOR
  DIRECTOR
}

enum FinanceEntryType {
  INCOME
  EXPENSE
}

enum InvoiceLineType {
  HOURS
  PERDIEM
  DEBOURS
  TRANSPORT
  OTHER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  role          Role      @default(CONSULTANT)
  avatar        String?
  phone         String?
  
  // Consultant Profile
  title         String?
  description   String?   @db.Text
  hourlyRate    Decimal   @default(0) @db.Decimal(10, 2)
  level         ConsultantLevel @default(JUNIOR)
  rating        Float     @default(0)
  skills        Json?     // Array of strings
  education     Json?     // Array of objects { degree, school, year }
  experience    Json?     // Array of objects { title, company, duration, description }

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  projects      Project[] @relation("ProjectManager")
  assignedTasks Task[]    @relation("TaskAssignees")
  createdTasks  Task[]    @relation("TaskCreator")
  comments      Comment[]
  invoices      Invoice[]
  payments      Payment[]
  workedHours   TaskHours[]
  financeEntries FinanceEntry[]
  notifications Notification[]
  
  consultingProjects Project[] @relation("ProjectConsultants")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(PENDING)
  type        ProjectType   @default(JURIDIQUE)
  
  clientName    String?
  clientContact String?
  clientPhone   String?
  clientEmail   String?
  
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  managerId   String
  manager     User          @relation("ProjectManager", fields: [managerId], references: [id])
  
  consultants User[]        @relation("ProjectConsultants")
  
  priority    ProjectPriority @default(MEDIUM)
  progress    Int             @default(0)
  expertise   String?
  
  tasks       Task[]
  invoices    Invoice[]
  financeEntries FinanceEntry[]
}

model Task {
  id              String     @id @default(cuid())
  title           String
  description     String?    @db.Text
  status          TaskStatus @default(TODO)
  priority        Int        @default(1)
  
  // Budget Breakdown
  budget          Decimal    @default(0) @db.Decimal(10, 2) // Total
  budgetDebours   Decimal    @default(0) @db.Decimal(10, 2)
  budgetPerdiem   Decimal    @default(0) @db.Decimal(10, 2)
  budgetTransport Decimal    @default(0) @db.Decimal(10, 2)
  
  dueDate         DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  projectId       String
  project         Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Assignees (Many-to-Many)
  assignees       User[]     @relation("TaskAssignees")
  
  creatorId       String
  creator         User       @relation("TaskCreator", fields: [creatorId], references: [id])

  subtasks        SubTask[]
  comments        Comment[]
  workedHours     TaskHours[]
  invoiceLines    InvoiceLine[]
  financeEntries  FinanceEntry[]
}

model SubTask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Comment {
  id          String   @id @default(cuid())
  content     String   @db.Text
  attachments Json?    // Array of file URLs/Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  
  // Amounts
  subtotal    Decimal       @default(0) @db.Decimal(12, 2)
  taxRate     Decimal       @default(19.25) @db.Decimal(5, 2) // Cameroon TVA
  tax         Decimal       @default(0) @db.Decimal(12, 2)
  total       Decimal       @default(0) @db.Decimal(12, 2)
  
  status      InvoiceStatus @default(DRAFT)
  validated   Boolean       @default(false)
  dueDate     DateTime?
  paidDate    DateTime?
  description String?       @db.Text
  pdfUrl      String?
  reminderSentAt DateTime?
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id])
  
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  
  payments    Payment[]
  lines       InvoiceLine[]
  entries     FinanceEntry[]
}

model InvoiceLine {
  id          String          @id @default(cuid())
  type        InvoiceLineType @default(OTHER)
  description String
  quantity    Decimal         @db.Decimal(10, 2)
  unitPrice   Decimal         @db.Decimal(12, 2)
  amount      Decimal         @db.Decimal(12, 2)
  
  taskId      String?
  task        Task?           @relation(fields: [taskId], references: [id])
  
  invoiceId   String
  invoice     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String        @id @default(cuid())
  amount      Decimal       @db.Decimal(10, 2)
  status      PaymentStatus @default(PENDING)
  method      String?
  reference   String?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User          @relation(fields: [userId], references: [id])
}

model TaskHours {
  id          String   @id @default(cuid())
  hours       Decimal  @db.Decimal(5, 2)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
}

model FinanceEntry {
  id          String           @id @default(cuid())
  type        FinanceEntryType
  amount      Decimal          @db.Decimal(12, 2)
  description String
  category    String?
  date        DateTime         @default(now())
  createdAt   DateTime         @default(now())
  
  projectId   String?
  project     Project?         @relation(fields: [projectId], references: [id])
  
  taskId      String?
  task        Task?            @relation(fields: [taskId], references: [id])
  
  invoiceId   String?
  invoice     Invoice?         @relation(fields: [invoiceId], references: [id])
  
  createdById String
  createdBy   User             @relation(fields: [createdById], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // ASSIGNMENT, TASK, COMMENT, FILE, INVOICE, PAYMENT
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
